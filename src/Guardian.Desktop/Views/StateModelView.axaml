<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Guardian.Desktop.ViewModels"
             x:Class="Guardian.Desktop.Views.StateModelView"
             x:DataType="vm:StateModelViewModel">

    <Border Classes="panel" Margin="4">
        <StackPanel>
            <TextBlock Classes="panel-header" Text="State Model" />

            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,4">
                <!-- Flight Phase -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Phase" FontSize="12" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentPhase}"
                           FontSize="14" FontWeight="Bold" />

                <!-- Aircraft -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Aircraft" FontSize="12" Margin="0,8,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AircraftName}"
                           FontSize="12" Margin="0,8,0,0" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Profile ID" FontSize="11" Opacity="0.6" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AircraftId}"
                           FontSize="11" Classes="mono" Opacity="0.6" />

                <!-- Engine config -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Engines" FontSize="12" Margin="0,8,0,0" />
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <TextBlock Text="{Binding EngineCount}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="x" FontSize="12" Opacity="0.5" />
                    <TextBlock Text="{Binding EngineType}" FontSize="12" />
                </StackPanel>

                <!-- Fuel config -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Fuel" FontSize="12" Margin="0,4,0,0" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FuelConfig}"
                           FontSize="12" Margin="0,4,0,0" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
