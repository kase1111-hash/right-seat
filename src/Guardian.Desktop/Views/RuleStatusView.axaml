<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Guardian.Desktop.ViewModels"
             x:Class="Guardian.Desktop.Views.RuleStatusView"
             x:DataType="vm:RuleStatusViewModel">

    <Border Classes="panel" Margin="4">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Classes="panel-header" Text="Detection Rules" />
                <TextBlock FontSize="11" Opacity="0.6" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} active / {1} disabled">
                            <Binding Path="EnabledCount" />
                            <Binding Path="DisabledCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding Rules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RuleEntryViewModel">
                        <Grid ColumnDefinitions="50,*,100" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="{Binding RuleId}"
                                       FontWeight="SemiBold" FontSize="12" Classes="mono" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       FontSize="12" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding StateDisplay}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       Foreground="{Binding StateClass}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>
